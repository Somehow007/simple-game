{
  "name": "@shudu/ui",
  "version": "0.0.0",
  "private": true,
  "description": "共享 UI 组件库",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
